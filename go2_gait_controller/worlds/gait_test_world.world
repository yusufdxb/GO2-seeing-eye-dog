<?xml version="1.0" ?>
<!--
  GO2 Gait Controller — Test World
  Flat ground plane for gait testing.
  Includes terrain ramps for walk/trot validation.
-->
<sdf version="1.6">
  <world name="gait_test_world">

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!-- Physics tuned for legged robot contact -->
    <physics name="default_physics" default="0" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- Low ramp for walk gait testing (5 degree incline) -->
    <model name="ramp_walk">
      <static>true</static>
      <pose>4.0 0 0.17 0 -0.087 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>4.0 2.0 0.02</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>4.0 2.0 0.02</size></box></geometry>
          <material><ambient>0.6 0.8 0.6 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Steeper ramp for trot gait testing (10 degree incline) -->
    <model name="ramp_trot">
      <static>true</static>
      <pose>4.0 3.0 0.35 0 -0.175 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>4.0 2.0 0.02</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>4.0 2.0 0.02</size></box></geometry>
          <material><ambient>0.8 0.7 0.5 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Obstacle for walk gait avoidance testing -->
    <model name="obstacle_box">
      <static>true</static>
      <pose>2.0 -2.0 0.15 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.4 0.4 0.3</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.4 0.4 0.3</size></box></geometry>
          <material><ambient>0.8 0.3 0.3 1</ambient></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
